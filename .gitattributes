# Normalize line endings to LF on commit
* text=auto eol=lf

# Explicitly LF
*.ts   text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.sh   text eol=lf
*.css  text eol=lf
*.html text eol=lf

# Binary — never touch
*.node  binary
*.onnx  binary
*.png   binary
*.jpg   binary
*.gif   binary
*.ico   binary
*.wasm  binary
