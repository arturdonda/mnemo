{
	"name": "mnemo-cli",
	"version": "1.5.1",
	"description": "Your codebase, remembered — across every AI session. Persistent context for AI coding agents.",
	"type": "module",
	"bin": {
		"mnemo": "dist/cli.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc",
		"dev": "node --loader ts-node/esm src/cli.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "tsc --noEmit",
		"bench": "vitest run tests/benchmarks/"
	},
	"dependencies": {
		"@lancedb/lancedb": "^0.27.2",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@node-rs/xxhash": "^1.7.6",
		"better-sqlite3": "^12.9.0",
		"chokidar": "^5.0.0",
		"commander": "^14.0.3",
		"fast-glob": "^3.3.3",
		"onnxruntime-node": "^1.25.1",
		"simple-git": "^3.36.0",
		"sqlite-vec": "^0.1.9"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^25.6.0",
		"ts-node": "^10.9.2",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	},
	"engines": {
		"node": ">=20"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/arturdonda/mnemo.git"
	},
	"homepage": "https://arturdonda.github.io/mnemo",
	"bugs": {
		"url": "https://github.com/arturdonda/mnemo/issues"
	},
	"keywords": [
		"ai",
		"agents",
		"context",
		"memory",
		"codebase",
		"cli",
		"claude",
		"copilot",
		"codex",
		"cursor",
		"mcp"
	]
}
