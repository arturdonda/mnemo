{
	"name": "mnemo-cli",
	"version": "0.1.0",
	"description": "Your codebase, remembered — across every AI session. Persistent context for AI coding agents.",
	"type": "module",
	"bin": {
		"mnemo": "./dist/cli.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"prepublishOnly": "npm run build && npm run test",
		"build": "tsc",
		"dev": "node --loader ts-node/esm src/cli.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [
		"ai",
		"agents",
		"context",
		"memory",
		"codebase",
		"cli",
		"claude",
		"copilot",
		"codex",
		"cursor",
		"mcp"
	],
	"engines": {
		"node": ">=20"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/arturdonda/mnemo"
	},
	"homepage": "https://github.com/arturdonda/mnemo#readme",
	"bugs": {
		"url": "https://github.com/arturdonda/mnemo/issues"
	}
}
